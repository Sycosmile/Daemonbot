# ── Copy this to .env and fill in your values ──

# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Bot username without @ (e.g. Daemonbot)
BOT_USERNAME=Daemonbot

# Groq API key (free — sign up at console.groq.com) — powers AI chat personality
GROQ_API_KEY=your_groq_key_here

# Optional — override the default model (llama-3.3-70b-versatile).
AI_MODEL=

# Optional — for enhanced Solana top holders. NOTE: Birdeye's data API is paid
# now (~$39/mo+), the free tier is eval-only. Holder/security data uses RugCheck
# instead (free, no key) — this is only here if you've actually paid for Birdeye.
BIRDEYE_API_KEY=

# Optional — Solana RPC for the Dev Sold check + fresh-wallet heuristic on
# /scan and /z. Get a free key at fluxrpc.com (10GB/mo free). Leave blank to
# fall back to the public Solana RPC (works, just slower/rate-limited).
FLUXRPC_URL=https://eu.fluxrpc.com
FLUXRPC_API_KEY=

# Optional — for ETH/BSC contract info
ETHERSCAN_KEY=
BSCSCAN_KEY=

# Optional — raises GitHub API limit from 60/hr to 5,000/hr for /gh
GITHUB_TOKEN=

# Optional, free signup at https://finnhub.io/register — powers /cal
FINNHUB_API_KEY=
